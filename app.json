{
  "expo": {
    "name": "Clork",
    "slug": "clork",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "clork",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.kyks.clork",
      "supportsTablet": false
    },
    "android": {
      "package": "com.kyks.clork",
      "adaptiveIcon": {
        "backgroundColor": "#FFC233",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-calendar",
        {
          "calendarPermission": "Clork ajoute tes horaires de travail dans ton calendrier."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Clork utilise l'appareil photo pour scanner le planning affiché en magasin.",
          "photosPermission": "Clork accède à tes photos pour importer une photo du planning."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFC233",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
