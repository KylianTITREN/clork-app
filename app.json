{
  "expo": {
    "name": "Clork",
    "slug": "clork",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "clork",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.kyks.clork",
      "supportsTablet": false,
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.kyks.clork.shared",
          "group.com.kyks.clork.shared"
        ]
      },
      "appleTeamId": "VA859P9KT5",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.kyks.clork",
      "adaptiveIcon": {
        "backgroundColor": "#26210E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@bacons/apple-targets",
      [
        "expo-calendar",
        {
          "calendarPermission": "Clork ajoute tes horaires de travail dans ton calendrier."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Clork utilise l'appareil photo pour scanner le planning affiché en magasin.",
          "photosPermission": "Clork accède à tes photos pour importer une photo du planning."
        }
      ],
      [
        "expo-alternate-app-icons",
        [
          {
            "name": "honey",
            "ios": "./assets/icons/icon-honey.png"
          },
          {
            "name": "blossom",
            "ios": "./assets/icons/icon-blossom.png"
          },
          {
            "name": "plum",
            "ios": "./assets/icons/icon-plum.png"
          },
          {
            "name": "water",
            "ios": "./assets/icons/icon-water.png"
          },
          {
            "name": "sage",
            "ios": "./assets/icons/icon-sage.png"
          },
          {
            "name": "graphite",
            "ios": "./assets/icons/icon-graphite.png"
          }
        ]
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#26210E",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 140
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a43416c5-1c32-4e33-8d72-3a54e8e0c1f3",
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "com.kyks.clork.widgets",
                  "targetName": "ClorkWidgets",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.kyks.clork.shared"
                    ]
                  }
                }
              ]
            }
          }
        }
      },
      "pushEnabled": false
    },
    "owner": "kyksio",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a43416c5-1c32-4e33-8d72-3a54e8e0c1f3"
    }
  }
}
