{
  "expo": {
    "name": "Clork",
    "slug": "clork",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "clork",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.kyks.clork",
      "supportsTablet": false
    },
    "android": {
      "package": "com.kyks.clork",
      "adaptiveIcon": {
        "backgroundColor": "#FFC233",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-calendar",
        {
          "calendarPermission": "Clork ajoute tes horaires de travail dans ton calendrier."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Clork utilise l'appareil photo pour scanner le planning affiché en magasin.",
          "photosPermission": "Clork accède à tes photos pour importer une photo du planning."
        }
      ],
      [
        "expo-alternate-app-icons",
        [
          {
            "name": "honey",
            "ios": "./assets/icons/icon-honey.png"
          },
          {
            "name": "blossom",
            "ios": "./assets/icons/icon-blossom.png"
          },
          {
            "name": "plum",
            "ios": "./assets/icons/icon-plum.png"
          },
          {
            "name": "water",
            "ios": "./assets/icons/icon-water.png"
          },
          {
            "name": "sage",
            "ios": "./assets/icons/icon-sage.png"
          },
          {
            "name": "graphite",
            "ios": "./assets/icons/icon-graphite.png"
          }
        ]
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFC233",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a43416c5-1c32-4e33-8d72-3a54e8e0c1f3"
      }
    },
    "owner": "kyksio"
  }
}
